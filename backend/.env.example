NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erpstock?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Email (SMTP) — Яндекс.Почта для домена
# Инструкция: https://yandex.ru/support/mail/mail-clients/others.html
# SMTP_PASS — пароль приложения из настроек Яндекс ID → Безопасность → Пароли приложений
SMTP_ENABLED=false
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.ru
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.ru

# ERP Integration
ERP_TYPE=moysklad
MOYSKLAD_BASE_URL=https://api.moysklad.ru/api/remap/1.2
MOYSKLAD_TOKEN=

# Notifications
OPERATOR_EMAIL=

# Frontend URL (for CORS etc.)
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=uploads

# Logging
LOG_LEVEL=info
